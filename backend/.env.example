# ============================================
# Electricity Bills Recognition - 环境配置
# ============================================
# 复制此文件为 .env 并填入真实值

# --- LLM 配置 (必填) ---
LLM_PROVIDER=deepseek
LLM_MODEL_NAME=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.deepseek.com

# --- 安全配置 (生产环境必须修改) ---
# 随机生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- MongoDB (可选) ---
# MONGODB_URI=mongodb://localhost:27017
# DATABASE_NAME=electricity_bills

# --- CORS (生产环境必须修改) ---
# 支持两种格式:
#   逗号分隔: CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
#   JSON数组:  CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]
# CORS_ORIGINS=http://localhost:5173

# --- OCR 并发 (可选) ---
# OCR_MAX_CONCURRENCY=1

# --- Embedding 模型 (可选) ---
# EMBEDDING_MODEL_PATH=models/embedding/default
# RERANK_MODEL_PATH=
